---
import { getEntry, getCollection, render } from 'astro:content';
import ContentLayout from '../../layouts/ContentLayout.astro';
import { t, LANGS, isLang, type Lang } from '../../i18n/helpers';

export async function getStaticPaths() {
  return LANGS.map((lang) => ({ params: { lang } }));
}

const { lang: langParam } = Astro.params;
if (!langParam || !isLang(langParam)) throw new Error('Invalid lang');
const lang: Lang = langParam;

const page = await getEntry('pages', `contacts.${lang}`);
if (!page) throw new Error(`Missing contacts page for lang ${lang}`);
const { Content } = await render(page);

const settings = await getCollection('settings');
const contacts = settings.find((s) => s.id === 'contacts')?.data;
const privacyLinkText = t(lang, 'form.privacy_policy_link_text');
const consentTemplate = t(lang, 'form.privacy_consent');
const consentBefore = consentTemplate.split('{privacy_policy_link}')[0];
const consentAfter = consentTemplate.split('{privacy_policy_link}')[1] ?? '';
---

<ContentLayout
  title={`${page.data.title} — 361Robotics`}
  description={page.data.description}
  lang={lang}
  pathTail="contacts"
>
  <section class="py-8 max-w-2xl">
    <h1 class="text-3xl font-bold mb-4">{page.data.title}</h1>
    <div class="prose mb-8"><Content /></div>

    <form
      name="contact"
      method="POST"
      data-netlify="true"
      data-netlify-honeypot="bot-field"
      class="space-y-4"
      action={`/${lang}/contacts?sent=1`}
    >
      <input type="hidden" name="form-name" value="contact" />
      <p class="hidden">
        <label>Don't fill this out: <input name="bot-field" /></label>
      </p>

      <div>
        <label for="name" class="block text-sm font-medium mb-1">{t(lang, 'form.name')}</label>
        <input id="name" name="name" type="text" required class="w-full border border-border rounded px-3 py-2" />
      </div>
      <div>
        <label for="email" class="block text-sm font-medium mb-1">{t(lang, 'form.email')}</label>
        <input id="email" name="email" type="email" required class="w-full border border-border rounded px-3 py-2" />
      </div>
      <div>
        <label for="company" class="block text-sm font-medium mb-1">{t(lang, 'form.company')}</label>
        <input id="company" name="company" type="text" class="w-full border border-border rounded px-3 py-2" />
      </div>
      <div>
        <label for="message" class="block text-sm font-medium mb-1">{t(lang, 'form.message')}</label>
        <textarea id="message" name="message" required rows="5" class="w-full border border-border rounded px-3 py-2"></textarea>
      </div>
      <label class="flex items-start gap-2 text-sm">
        <input type="checkbox" name="privacy-consent" required class="mt-1" />
        <span>
          {consentBefore}<a class="text-accent" href={`/${lang}/privacy`}>{privacyLinkText}</a>{consentAfter}
        </span>
      </label>
      <button type="submit" class="bg-accent text-white px-5 py-2 rounded">{t(lang, 'form.submit')}</button>
    </form>

    {contacts && (
      <div class="mt-10 pt-6 border-t border-border text-sm text-muted space-y-1">
        <p><a class="text-accent" href={`mailto:${contacts.email}`}>{contacts.email}</a></p>
        {contacts.phone && <p>{contacts.phone}</p>}
        {contacts.whatsapp && <p>WhatsApp: {contacts.whatsapp}</p>}
        {contacts.wechat_id && <p>WeChat: {contacts.wechat_id}</p>}
        {contacts.telegram_handle && (
          <p class="pt-2">
            <a
              href={`https://t.me/${contacts.telegram_handle.replace(/^@/, '')}`}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 no-underline text-ink hover:text-accent"
              aria-label="Telegram"
            >
              <svg viewBox="0 0 24 24" width="24" height="24" fill="currentColor" aria-hidden="true">
                <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z" />
              </svg>
              <span>Telegram</span>
            </a>
          </p>
        )}
      </div>
    )}
  </section>

  {Astro.url.searchParams.get('sent') === '1' && (
    <div class="fixed bottom-6 right-6 max-w-sm bg-ink text-white p-4 rounded-lg shadow-lg">
      <p class="font-semibold">{t(lang, 'form.thank_you_title')}</p>
      <p class="text-sm mt-1">{t(lang, 'form.thank_you_body')}</p>
    </div>
  )}
</ContentLayout>
